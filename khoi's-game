<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Mini 10MB Game</title>
<style>
body {
    margin: 0;
    overflow: hidden;
    background: #111;
    font-family: Arial;
    color: white;
}
#box {
    width: 50px;
    height: 50px;
    background: red;
    position: absolute;
}
#score {
    position: fixed;
    top: 10px;
    left: 10px;
}
</style>
</head>
<body>

<div id="score">Score: 0</div>
<div id="box"></div>

<script>
let box = document.getElementById("box");
let scoreText = document.getElementById("score");

let x = 100;
let y = 100;
let dx = 2;
let dy = 2;
let score = 0;

function move() {
    x += dx;
    y += dy;

    if (x < 0 || x > window.innerWidth - 50) dx *= -1;
    if (y < 0 || y > window.innerHeight - 50) dy *= -1;

    box.style.left = x + "px";
    box.style.top = y + "px";

    requestAnimationFrame(move);
}

box.onclick = function() {
    score++;
    scoreText.innerText = "Score: " + score;
    dx *= 1.1;
    dy *= 1.1;
};

move();
</script>

</body>
</html>
